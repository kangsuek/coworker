# Claude CLI 설정
CLAUDE_CLI_PATH=claude                # claude CLI 실행 경로 (PATH에 등록된 경우 기본값)
CLAUDE_CLI_TIMEOUT=120                # Sub-Agent 1회 호출 타임아웃 (초)

# 모델 설정 (빈 값이면 CLI 기본 모델 사용)
SOLO_MODEL=claude-haiku-4-5-20251001  # 분류 + Solo 응답용 (빠르고 저렴)
TEAM_MODEL=claude-sonnet-4-6          # Team 에이전트 + 통합용 (고성능)

# Agent 설정
MAX_SUB_AGENTS=5                      # Team 모드 최대 Sub-Agent 수

# 세션 설정
SESSION_TTL_SECONDS=3600
DB_PATH=./data/coworker.db

# 서버 설정
CORS_ORIGINS=http://localhost:5173    # 프론트엔드 개발 서버 (쉼표 구분으로 복수 지정 가능)

# Team 모드 트리거 해더 메시지 (미설정 시 solo 모드만 사용)
# TEAM_TRIGGER_HEADER=(팀모드)

# 분류 설정: 역할별 키워드 (쉼표 구분, 미설정 시 기본값 사용)
# 순서(우선순위)는 코드에 고정 — Writer가 Planner보다 먼저 매칭됨 
# ROLE_RESEARCHER_KEYWORDS=조사,리서치,분석,시장,경쟁사,데이터 수집,현황,정보 수집
# ROLE_WRITER_KEYWORDS=마케팅,홍보,카피,콘텐츠,글쓰기,작성,문서,보고서
# ROLE_PLANNER_KEYWORDS=전략,기획,투자,유치,계획,로드맵,설계,아키텍처
# ROLE_CODER_KEYWORDS=코드,구현,개발,프로그래밍,기술,빌드
# ROLE_REVIEWER_KEYWORDS=리뷰,검토,테스트,감사,검증,평가,피드백
